VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI mode: demo | direct | supabase
# demo: no external AI call
# direct: browser calls the AI provider directly; use only for local experiments
# supabase: browser calls the Supabase Edge Function ai-proxy
VITE_AI_MODE=demo

# Direct browser mode only
VITE_AI_API_KEY=your-ai-api-key
VITE_AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/your-model:generateContent

# Supabase Edge Function secrets, set with:
# supabase secrets set AI_API_KEY=... AI_API_URL=...
# AI_API_KEY=your-ai-api-key
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/your-model:generateContent
