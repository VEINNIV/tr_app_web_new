# ─── Frontend (Vite — taraf-istemciye gömülür) ─────────────
# DİKKAT: VITE_ önekli her şey bundle'a girer ve herkesçe görülebilir.
# Bu yüzden AI API key burada DEĞİL — sadece Supabase edge function'da.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Opsiyonel: backend PDF servisi (varsa)
# VITE_PDF_SERVICE_URL=http://localhost:5050

# ─── Supabase Edge Function secrets ────────────────────────
# (Bunlar `.env`'e DEĞİL, Supabase Dashboard → Project Settings →
# Edge Functions → Secrets üzerinden ya da `supabase secrets set`
# komutuyla ayarlanır. Aşağıdaki örnekler referans amaçlıdır.)
#
# AI_API_KEY=your-gemini-api-key
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
# ALLOWED_ORIGINS=https://translingua.app,https://www.translingua.app
